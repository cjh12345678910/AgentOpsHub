# Agent Runtime local configuration example
AGENT_LLM_PROVIDER=openai-compatible
AGENT_LLM_API_KEY=your_api_key_here
AGENT_LLM_MODEL=deepseek-v3
AGENT_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AGENT_LLM_TIMEOUT_MS=20000
AGENT_LLM_RETRY_MAX=1

AGENT_REPAIR_ENABLED=true
AGENT_MAX_REPAIR_ROUNDS=2
AGENT_VERIFIER_COVERAGE_THRESHOLD=0.70
